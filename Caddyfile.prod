# Production Caddy configuration — HTTP only (Cloudflare handles TLS)
:80 {
    # Security headers (Cloudflare adds HSTS)
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Health endpoint
    handle /health {
        reverse_proxy mcp-server:8081
    }

    # MCP Server — Streamable HTTP with SSE
    handle /mcp* {
        reverse_proxy mcp-server:8081 {
            flush_interval -1
            header_up Accept-Encoding identity
            header_down Cache-Control no-cache
            header_down X-Accel-Buffering no
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
        }
    }

    # OAuth discovery
    handle /.well-known/* {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
        }
    }

    # OAuth endpoints (Claude.ai hardcodes these paths)
    handle /authorize {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
        }
    }

    handle /token {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
        }
    }

    handle /register {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
        }
    }

    handle /revoke {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
        }
    }

    # Enable Banking callback
    handle /auth/* {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-Host {host}
        }
    }

    # Default
    handle {
        respond "ADHD Budget Assistant" 200
    }
}
