# Production Caddy configuration with HTTPS
adhdbudget.bieda.it {
    # Automatic HTTPS with Let's Encrypt
    tls

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # Health endpoint
    handle /health {
        reverse_proxy mcp-server:8081
    }

    # MCP Server — Streamable HTTP with SSE support
    handle /mcp* {
        reverse_proxy mcp-server:8081 {
            flush_interval -1
            header_up Accept-Encoding identity
            header_down Cache-Control no-cache
            header_down X-Accel-Buffering no
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    # OAuth discovery endpoints
    handle /.well-known/* {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    # OAuth endpoints (Claude.ai hardcodes these paths)
    handle /authorize {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    handle /token {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    handle /register {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    handle /revoke {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    # Enable Banking callback
    handle /auth/* {
        reverse_proxy mcp-server:8081 {
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-Host {host}
        }
    }

    # Default handler
    handle {
        respond "ADHD Budget Assistant" 200
    }
}

# HTTP to HTTPS redirect
http://adhdbudget.bieda.it {
    redir https://{host}{uri} permanent
}
